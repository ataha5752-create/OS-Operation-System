# Port the server will listen on (Railway sets this automatically)
PORT=3000

# Secret key for JWT authentication (Change this to a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Set to true to disable HTTPS (Self-signed certs) and run on HTTP. 
# REQUIRED ON RAILWAY since Railway handles SSL termination.
DISABLE_SSL=true

# Persistent paths for database and uploads (Point to Railway's persistent volume mount, e.g. /data)
SQLITE_DB_PATH=/data/data.db
UPLOADS_DIR=/data/uploads

# --- SMTP Email Notifications (Optional) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_email_password

# --- Telegram Notifications (Optional) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id_1,your_chat_id_2

# --- SMS / WhatsApp Notifications (Optional) ---
SMS_GATEWAY_URL=https://your-sms-gateway.com/api
WHATSAPP_API_TOKEN=your_whatsapp_token
